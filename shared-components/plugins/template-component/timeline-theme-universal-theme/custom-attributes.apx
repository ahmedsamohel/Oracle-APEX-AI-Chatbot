    security {
        escapeMode: htmlAttribute
    }
    appearance {
        sequence: 200
    }
    help {
        helpText: Set the style of timeline items.
    }

    entry compact (
        sequence: 10
        display: Compact
        return: t-Timeline--compact
    )

)

