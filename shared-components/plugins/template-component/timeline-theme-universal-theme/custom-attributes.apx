    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Enter an icon class or use the Pick Icon dialog to select the icon you want to add to display in the badge.
    }
)

customAttribute BADGE_LABEL (
    apexlangName: label
    attribute: 13
    name: Label
    validation {
        required: true
    }
    security {
        escapeMode: raw
    }
    appearance {
        attributeGroup: @badge
        sequence: 130
    }
    builder {
        translatable: true
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Enter a value for the badge label or select a source column from the quick pick options.
    }
)

customAttribute BADGE_LABEL_DISPLAY (
    apexlangName: displayLabel
    attribute: 17
    name: Display Label
    type: yesNo
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @badge
        sequence: 170
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Specify whether to display or hide the badge label. When set to Yes, the badge label will be displayed in addition to the badge value. When set to No, only the badge value will be displayed.
    }
)

customAttribute BADGE_SHAPE (
    apexlangName: shape2
    attribute: 19
    name: Shape
    type: selectList
    componentLov {
        nullText: Default
    }
    appearance {
        attributeGroup: @badge
        sequence: 190
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select the shape of the badge. Default inherits the shape set by the containing template.
    }

    entry circular (
        sequence: 20
        display: Circular
        return: t-Badge--circle
        help {
            helpText: Displayed with circular edges.
        }
    )

    entry rounded (
        sequence: 10
        display: Rounded
        return: t-Badge--rounded
        help {
            helpText: Displayed with rounded corners.
        }
    )

    entry square (
        sequence: 30
        display: Square
        return: t-Badge--square
        help {
            helpText: Displayed with squared edges.
        }
    )

)

customAttribute BADGE_STATE (
    apexlangName: state
    attribute: 15
    name: State
    type: sessionStateValue
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @badge
        sequence: 150
    }
    default {
        sampleDataValue: is-removed
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select the source column for the state of the badge. Substitute column value with "danger", "warning", "success" or "info" for default styling.
    }
)

customAttribute BADGE_STYLE (
    apexlangName: style
    attribute: 18
    name: Style
    type: selectList
    componentLov {
        nullText: Default
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @badge
        sequence: 180
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select the badge style. Default inherits the style set by the containing template.
    }

    entry outline (
        sequence: 20
        display: Outline
        return: t-Badge--outline
    )

    entry subtle (
        sequence: 10
        display: Subtle
        return: t-Badge--subtle
    )

)

customAttribute BADGE_VALUE (
    apexlangName: value
    attribute: 14
    name: Value
    type: sessionStateValue
    validation {
        required: true
    }
    security {
        escapeMode: stripHtml
    }
    appearance {
        attributeGroup: @badge
        sequence: 140
    }
    default {
        sampleDataValue: Closed
    }
    supports {
        dataTypes: [
            varchar2
            number
            date
            intervalYearToMonth
            intervalDayToSecond
        ]
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select a source column for the badge value.
    }
)

customAttribute DATE (
    apexlangName: date
    attribute: 2
    name: Date
    type: sessionStateValue
    validation {
        required: true
    }
    appearance {
        sequence: 20
    }
    default {
        sampleDataValue: 1 hour ago
    }
    supports {
        dataTypes: [
            varchar2
            number
            date
            intervalYearToMonth
            intervalDayToSecond
        ]
    }
    help {
        helpText: Select a source column containing a date, date range, or time.
    }
)

customAttribute DESCRIPTION (
    apexlangName: description
