customAttribute APPLY_THEME_COLORS (
    apexlangName: applyThemeColors
    attribute: 21
    name: Apply Theme Colors
    scope: report
    type: yesNo
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        sequence: 210
    }
    default {
        value: true
        sampleDataValue: Y
    }
    help {
        helpText: Specify whether to use the Universal Theme colors for avatar and badge row items. When set to Yes, the u-colors class will be applied to each row. When set to No, a default color will be used instead.
    }
)

customAttribute AVATAR_DESCRIPTION (
    apexlangName: description2
    attribute: 9
    name: Description
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @avatar
        sequence: 115
    }
    builder {
        translatable: true
    }
    dependingOn {
        attribute: @DISPLAY_AVATAR/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Enter a short description of the image/icon or select a source column from the quick pick options. This will be used as title & alt text for the avatar image/icon.
    }
)

customAttribute AVATAR_ICON (
    apexlangName: icon
    attribute: 11
    name: Icon
    type: icon
    validation {
        required: true
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @avatar
        sequence: 110
    }
    default {
        value: fa-user
    }
    dependingOn {
        attribute: @AVATAR_TYPE/component
        conditionType: =
        value: icon
    }
    help {
        helpText: Enter an icon class or use the Pick Icon dialog to select the icon you want to add to display in the avatar.
    }
)

customAttribute AVATAR_IMAGE (
    apexlangName: image
    attribute: 8
    name: Image
    type: media
    validation {
        required: true
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @avatar
        sequence: 80
    }
    dependingOn {
        attribute: @AVATAR_TYPE/component
        conditionType: =
        value: image
    }
    help {
        helpText:
            ```
            <p>Use the Media popup dialog to select a source for the avatar image.</p>
            
            <p>Available options include:
            <ul>
            <li>URL</li>
            <li>BLOB Column</li>
            <li>URL Column</li>
            </ul>
            </p>
            ```
    }
)

customAttribute AVATAR_INITIALS (
    apexlangName: initials
    attribute: 10
    name: Initials
    type: sessionStateValue
    validation {
        required: true
    }
    security {
        escapeMode: stripHtml
    }
    appearance {
        attributeGroup: @avatar
        sequence: 100
    }
    dependingOn {
        attribute: @AVATAR_TYPE/component
        conditionType: =
        value: initials
    }
    help {
        helpText: Select the source column to be displayed within each avatar. Only varchar2 data types are supported.
    }
)

customAttribute AVATAR_SHAPE (
    apexlangName: shape
    attribute: 12
    name: Shape
    type: selectList
    validation {
        required: true
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @avatar
        sequence: 120
    }
    default {
        value: t-Avatar--circle
    }
    dependingOn {
        attribute: @DISPLAY_AVATAR/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select the shape of the avatar. Default inherits the shape set by the containing template.
    }

    entry circular (
        sequence: 20
        display: Circular
        return: t-Avatar--circle
        help {
            helpText: Displayed within a circular shape.
        }
    )

    entry noShape (
        sequence: 40
        display: No Shape
        return: t-Avatar--noShape
        help {
            helpText: Displayed inline without a containing shape.
        }
    )

    entry rounded (
        sequence: 10
        display: Rounded
        return: t-Avatar--rounded
        help {
            helpText: Displayed within a square with rounded corners.
        }
    )

    entry square (
        sequence: 30
        display: Square
        return: t-Avatar--square
        help {
            helpText: Displayed within a square shape.
        }
    )

)

customAttribute AVATAR_TYPE (
    apexlangName: type
    attribute: 7
    name: Type
    type: selectList
    validation {
        required: true
    }
    appearance {
        attributeGroup: @avatar
        sequence: 70
    }
    default {
        value: icon
        sampleDataValue: icon
    }
    dependingOn {
        attribute: @DISPLAY_AVATAR/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select the type of content that will be displayed in the avatar.
    }

    entry icon (
        sequence: 30
        display: Icon
        return: icon
    )

    entry image (
        sequence: 10
        display: Image
        return: image
    )

    entry initials (
        sequence: 20
        display: Initials
        return: initials
    )

)

customAttribute BADGE_ICON (
    apexlangName: icon2
    attribute: 16
    name: Icon
    type: icon
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @badge
        sequence: 160
    }
    default {
        sampleDataValue: fa-check-circle-o
