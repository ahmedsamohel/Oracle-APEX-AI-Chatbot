regionTemplate title-bar (
    name: Title Bar
    templateClass: breadcrumbRegion
    templateOptions {
        preset: t-BreadcrumbRegion--useBreadcrumbTitle
        default: t-BreadcrumbRegion--showBreadcrumb
    }
    region {
        template:
            ```html
            <nav id="#REGION_STATIC_ID#" #REGION_LANDMARK_ATTRIBUTES# #REGION_ATTRIBUTES# class="t-BreadcrumbRegion #REGION_CSS_CLASSES#">
              <div class="t-BreadcrumbRegion-top">
                <div class="t-BreadcrumbRegion-buttons t-BreadcrumbRegion-buttons--start">#UP#</div>
                <div class="t-BreadcrumbRegion-body">
                  <div class="t-BreadcrumbRegion-breadcrumb">#BODY#</div>
                    <div class="t-BreadcrumbRegion-title">
                    <h1 id="#REGION_STATIC_ID#_heading" class="t-BreadcrumbRegion-titleText" data-apex-heading>#TITLE#</h1>
                  </div>
                </div>
                <div class="t-BreadcrumbRegion-buttons t-BreadcrumbRegion-buttons--end">#PREVIOUS##CLOSE##DELETE##HELP##CHANGE##EDIT##COPY##CREATE##NEXT#</div>
              </div>
              <div class="t-BreadcrumbRegion-bottom">#SMART_FILTERS#</div>
            </nav>
            
            ```
    }
    accessibility {
        landmarkType: navigation
    }
    advanced {
        identifier: TITLE_BAR
    }
    subscription {
        master: @title-bar
    }

    templateOption hide-breadcrumb (
        name: Show Breadcrumbs
        sequence: 1
        appearance {
            cssClasses: t-BreadcrumbRegion--showBreadcrumb
        }
        advanced {
            identifier: HIDE_BREADCRUMB
        }
    )

    templateOption use-compact-style (
        name: Use Compact Style
        sequence: 10
        appearance {
            cssClasses: t-BreadcrumbRegion--compactTitle
        }
        help {
            helpText: Uses a compact style for the breadcrumbs.
        }
        advanced {
            identifier: USE_COMPACT_STYLE
        }
    )

    templateOption heading-font-alternative (
        name: Alternative
        group: @region/heading-font
        sequence: 1
        appearance {
            cssClasses: t-BreadcrumbRegion--headingFontAlt
        }
        advanced {
            identifier: HEADING_FONT_ALTERNATIVE
        }
    )

    templateOption get-title-from-breadcrumb (
        name: Use Current Breadcrumb Entry
        group: @region/region-title
        sequence: 1
        appearance {
            cssClasses: t-BreadcrumbRegion--useBreadcrumbTitle
        }
        advanced {
            identifier: GET_TITLE_FROM_BREADCRUMB
        }
    )

    templateOption region-header-visible (
        name: Use Region Title
        group: @region/region-title
        sequence: 1
        appearance {
            cssClasses: t-BreadcrumbRegion--useRegionTitle
        }
        advanced {
            identifier: REGION_HEADER_VISIBLE
        }
    )

    slot change (
        name: Change
        staticId: CHANGE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot close (
        name: Close
        staticId: CLOSE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot copy (
        name: Copy
        staticId: COPY
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot create (
        name: Create
        staticId: CREATE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot delete (
        name: Delete
        staticId: DELETE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot edit (
        name: Edit
        staticId: EDIT
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot help (
        name: Help
        staticId: HELP
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot next (
        name: Next
        staticId: NEXT
        supports {
            regions: false
            items: true
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot previous (
        name: Previous
        staticId: PREVIOUS
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot regionBody (
        name: Region Body
        staticId: BODY
        supports {
            items: true
            buttons: true
        }
    )

    slot searchFieldAndSmartFilters (
        name: Search Field and Smart Filters
        staticId: SMART_FILTERS
        supports {
            items: true
            buttons: true
        }
    )

    slot subRegions (
        name: Sub Regions
        staticId: SUB_REGIONS
    )

    slot up (
        name: Up
        staticId: UP
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

)

