        }
    )

    templateOption icons-plus-or-minus (
        name: Plus or Minus
        group: @region/collapsible-button-icons
        sequence: 1
        appearance {
            cssClasses: t-Region--hideShowIconsMath
        }
        help {
            helpText: Use the plus and minus icons for the expand and collapse button.
        }
        advanced {
            identifier: ICONS_PLUS_OR_MINUS
        }
    )

    templateOption conrtols-position-end (
        name: End
        group: @region/collapsible-icon-position
        sequence: 1
        appearance {
            cssClasses: t-Region--controlsPosEnd
        }
        help {
            helpText: Position the expand / collapse button to the end of the region header.
        }
        advanced {
            identifier: CONRTOLS_POSITION_END
        }
    )

    templateOption collapsed (
        name: Collapsed
        group: @region/default-state
        sequence: 20
        appearance {
            cssClasses: is-collapsed
        }
        advanced {
            identifier: COLLAPSED
        }
    )

    templateOption expanded (
        name: Expanded
        group: @region/default-state
        sequence: 10
        appearance {
            cssClasses: is-expanded
        }
        advanced {
            identifier: EXPANDED
        }
    )

    templateOption noborder (
        name: Remove Borders
        group: @region/style
        sequence: 10
        appearance {
            cssClasses: t-Region--noBorder
        }
        help {
            helpText: Removes borders from the region.
        }
        advanced {
            identifier: NOBORDER
        }
    )

    templateOption remove-ui-decoration (
        name: Remove UI Decoration
        group: @region/style
        sequence: 30
        appearance {
            cssClasses: t-Region--noUI
        }
        help {
            helpText: Removes UI decoration (borders, backgrounds, shadows, etc) from the region.
        }
        advanced {
            identifier: REMOVE_UI_DECORATION
        }
    )

    templateOption stacked (
        name: Stack Region
        group: @region/style
        sequence: 20
        appearance {
            cssClasses: t-Region--stacked
        }
        help {
            helpText: Removes side borders and shadows, and can be useful for accordions and regions that need to be grouped together vertically.
        }
        advanced {
            identifier: STACKED
        }
    )

    slot change (
        name: Change
        staticId: CHANGE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot close (
        name: Close
        staticId: CLOSE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot copy (
        name: Copy
        staticId: COPY
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot create (
        name: Create
        staticId: CREATE
        supports {
            regions: false
            items: true
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot edit (
        name: Edit
        staticId: EDIT
        supports {
            regions: false
            items: true
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot next (
        name: Next
        staticId: NEXT
        supports {
            regions: false
            items: true
            buttons: true
        }
        gridLayout {
            gridSupport: false
