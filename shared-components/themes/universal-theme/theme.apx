theme universal-theme (
    name: Universal Theme
    themeNumber: 42
    version: 23.2
    style {
        currentThemeStyle: @vita
    }
    javaScript {
        fileUrls: [
            #APEX_FILES#libraries/apex/#MIN_DIRECTORY#widget.stickyWidget#MIN#.js?v=#APEX_VERSION#
            #THEME_FILES#js/theme42#MIN#.js?v=#APEX_VERSION#
        ]
    }
    css {
        fileUrls: #THEME_FILES#css/Core#MIN#.css?v=#APEX_VERSION#
    }
    componentDefaults {
        page: @standard
        navigationBarList: @navigation-bar
        navigationMenuListPosition: side
        navigationMenuListTop: @top-navigation-menu
        navigationMenuListSide: @side-navigation-menu
        loginPage: @login
        errorPage: @login
        printerFriendlyPage: @standard
        breadcrumb: @breadcrumb
        button: @text
        defaultLabel: @optional-floating
        optionalLabel: @optional-floating
        requiredLabel: @required-floating
        list: @links-list
        region: @standard
        classicReport: @standard
    }
    regionDefaults {
        breadcrumbs: @title-bar
        charts: @standard
        forms: @standard
        lists: @standard
        reports: @standard
        wizards: @standard
        interactiveReports: @interactive-report
    }
    dialogDefaults {
        dialogContentRegion: @blank-with-attributes
        dialogButtonRegion: @buttons-container
        dialogPage: @modal-dialog
    }
    icons {
        library: fontApex
    }
    advanced {
        filePrefix: #APEX_FILES#themes/theme_42/23.2/
        identifier: UNIVERSAL_THEME
    }
    subscription {
        master: @/8842/universal-theme
    }

    style redwood-light (
        name: Redwood Light
        css {
            fileUrls: [
                #APEX_FILES#libraries/oracle-fonts/oraclesans-apex#MIN#.css?v=#APEX_VERSION#
                #THEME_FILES#css/Redwood#MIN#.css?v=#APEX_VERSION#
            ]
        }
        themeRollerAttributes {
            readOnly: true
            inputParameterFileUrls: #THEME_FILES#less/theme/Redwood-Theme.less
            outputCssFileUrl: #THEME_FILES#css/Redwood-Theme#MIN#.css?v=#APEX_VERSION#
        }
        advanced {
            endUserCanPick: true
        }
        subscription {
            master: @redwood-light
        }
    )

    style vita (
        name: Vita
        themeRollerAttributes {
            readOnly: true
            inputParameterFileUrls: #THEME_FILES#less/theme/Vita.less
            outputCssFileUrl: #THEME_FILES#css/Vita#MIN#.css?v=#APEX_VERSION#
        }
        advanced {
            endUserCanPick: true
            accessibilityTested: true
        }
        subscription {
            master: @vita
        }
    )

    style vita-dark (
        name: Vita - Dark
        themeRollerAttributes {
            readOnly: true
            inputParameterFileUrls: #THEME_FILES#less/theme/Vita-Dark.less
            outputCssFileUrl: #THEME_FILES#css/Vita-Dark#MIN#.css?v=#APEX_VERSION#
        }
        advanced {
            endUserCanPick: true
        }
        subscription {
            master: @vita-dark
        }
    )

    style vita-red (
        name: Vita - Red
        themeRollerAttributes {
            readOnly: true
            inputParameterFileUrls: #THEME_FILES#less/theme/Vita-Red.less
            outputCssFileUrl: #THEME_FILES#css/Vita-Red#MIN#.css?v=#APEX_VERSION#
        }
        advanced {
            endUserCanPick: true
        }
        subscription {
            master: @vita-red
        }
    )

    style vita-slate (
        name: Vita - Slate
        themeRollerAttributes {
            readOnly: true
            inputParameterFileUrls: #THEME_FILES#less/theme/Vita-Slate.less
            outputCssFileUrl: #THEME_FILES#css/Vita-Slate#MIN#.css?v=#APEX_VERSION#
        }
        advanced {
            endUserCanPick: true
        }
        subscription {
            master: @vita-slate
        }
    )

)

