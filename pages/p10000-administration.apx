page 10000 (
    name: Administration
    alias: ADMINISTRATION
    title: Administration
    pageGroup: @administration
    appearance {
        pageTemplate: @standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>The administration page allows application owners (Administrators) to configure the application and maintain common data used across the application.
            By selecting one of the available settings, administrators can potentially change how the application is displayed and/or features available to the end users.</p>
            <p>Access to this page should be limited to Administrators only.</p>
            ```
    }

    region access-control (
        name: Access Control
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @column-2
            slot: regionBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @feature-access-control
        }
    )

    region access-control-actions (
        name: Access Control Actions
        type: list
        source {
            list: @access-control
        }
        layout {
            sequence: 30
            parentRegion: @access-control
            slot: regionBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @media-list
            templateOptions: [
                #DEFAULT#
                u-colors
            ]
        }
    )

    region acl-information (
        name: ACL Information
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                    l_acl_scope varchar2(45);
                begin
                    l_acl_scope := apex_app_setting.get_value( p_name => 'ACCESS_CONTROL_SCOPE' );
                
                    if l_acl_scope = 'ALL_USERS' then
                        return apex_lang.message('APEX.FEATURE.ACL.INFO.ALL_USERS');
                    elsif l_acl_scope = 'ACL_ONLY' then
                        return apex_lang.message('APEX.FEATURE.ACL.INFO.ACL_ONLY');
                    else
                        return apex_lang.message('APEX.FEATURE.ACL.INFO.ACL_VALUE_INVALID', l_acl_scope);
                    end if;
                end;
                ```
        }
        layout {
            sequence: 10
            parentRegion: @access-control
            slot: regionBody
        }
        appearance {
            template: @alert
            templateOptions: [
                #DEFAULT#
                t-Alert--colorBG
                t-Alert--horizontal
                t-Alert--noIcon
                t-Alert--warning
                t-Alert--accessibleHeading
            ]
            cssClasses: margin-sm
        }
    )

    region application-administration (
        name: Application Administration
        type: list
        source {
            list: @application-administration
        }
        layout {
            sequence: 30
            parentRegion: @column
            slot: regionBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            listTemplate: @media-list
            templateOptions: [
                #DEFAULT#
                u-colors
            ]
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region column (
        name: Column 1
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    region column-2 (
        name: Column 2
        type: staticContent
        layout {
            sequence: 20
            slot: body
            startNewRow: false
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    region user-counts-report (
        name: User Counts Report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select r.role_name, (select count(*) from apex_appl_acl_user_roles ur where r.role_id = ur.role_id) user_count, r.role_id
                from apex_appl_acl_roles r
                where r.application_id = :APP_ID
                group by r.role_name, r.role_id
                order by 2 desc, 1
                ```
        }
        layout {
            sequence: 20
            parentRegion: @access-control
            slot: regionBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--stacked
                t-Region--scrollBody
                t-Region--noPadding
            ]
        }
        componentAppearance {
            template: @value-attribute-pairs-row
            templateOptions: [
                #DEFAULT#
                t-AVPList--rightAligned
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column ROLE_ID (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Role Id
                alignment: center
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

        column ROLE_NAME (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Role Name
                alignment: center
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

        column USER_COUNT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: User Count
                alignment: center
            }
            layout {
                sequence: 2
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

    )

    button add-user (
        buttonName: ADD_USER
        label: Add User
        layout {
            sequence: 10
            region: @access-control
            slot: edit
        }
        appearance {
            buttonTemplate: @text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-user-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10012
                clearCache: 10012
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report (
        name: Refresh Report
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @add-user
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @user-counts-report
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

