page 10011 (
    name: Manage User Access
    alias: MANAGE-USER-ACCESS
    title: Manage User Access
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>This page shows a report of the application users and the access level granted.</p>
            <p>Click on the column headings to sort and filter data, or click on the <strong>Actions</strong> button to customize column display and many additional advanced features.<br>
            Click the <strong>Reset</strong> button to reset the interactive report back to the default settings.</p>
            <p>Click the edit icon (yellow pencil) to edit the user details and access level, or to delete the user.</p>
            <p>Click <strong>Add User</strong>, at the top of the report, to add a new user and their access level.</p>
            ```
    }
    config {
        buildOption: @feature-access-control
    }

    region manage-user-access (
        name: Manage User Access
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                   user_name_lc USERNAME,
                   role_names ACCESS_ROLE
                from APEX_APPL_ACL_USERS
                where APPLICATION_ID = :APP_ID
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        link {
            linkColumn: customTarget
            target: {
                page: 10012
                items: {
                    P10012_ID: \#ID#\
                }
                action: resetPagination
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 6294132781035685
        }

        column ACCESS_ROLE (
            type: plainText
            heading {
                heading: Roles
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                primaryKey: true
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column USERNAME (
            type: plainText
            heading {
                heading: Username
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Manage User Access
        }

        savedReport 62970 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ACCESS_ROLE (
                sequence: 2
            )

            displayColumn USERNAME (
                sequence: 1
            )

            sort (
                column: USERNAME
                sort {
                    sequence: 2
                }
            )

        )

    )

    button add-multiple-users (
        buttonName: ADD_MULTIPLE_USERS
        label: Add Multiple Users
        layout {
            sequence: 30
            region: @manage-user-access
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10013
                clearCache: 10013
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button add-user (
        buttonName: ADD_USER
        label: Add User
        layout {
            sequence: 40
            region: @manage-user-access
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10012
                clearCache: 10012
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 20
            region: @manage-user-access
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @text-with-icon
            templateOptions: [
                t-Button--iconLeft
                t-Button--gapRight
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: &APP_PAGE_ID.
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report (
        name: Refresh Report
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @manage-user-access
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @manage-user-access
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

